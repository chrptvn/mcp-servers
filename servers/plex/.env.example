# Required: your Plex authentication token (X-Plex-Token)
# See: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your-plex-token-here

# Optional: base URL of your Plex server (default: http://localhost:32400)
PLEX_URL=http://localhost:32400

# Optional: host filesystem path to the movies root directory
# Required only for file management tools (move_file, list_directory, sync_libraries, organize_movies_by_genre)
# Example for a direct mount:
PLEX_MEDIA_PATH=/mnt/data/plex/media/movies

# Optional: Plex-internal (Docker/virtual) path to the same movies root directory
# Set this when Plex runs in a container and sees a different path than the host
# Example: Plex container mounts host /mnt/data/plex/media as /data
PLEX_VIRTUAL_PATH=/data/movies
